{
  "name": "opc",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "dist-electron/electron/main.js",
  "scripts": {
    "dev": "concurrently -k \"node node_modules/vite/bin/vite.js\" \"wait-on http://127.0.0.1:5173 && node node_modules/electron/cli.js .\"",
    "build": "powershell -NoProfile -ExecutionPolicy Bypass -Command \"& { node 'node_modules/vite/bin/vite.js' build; if ($LASTEXITCODE -ne 0) { exit $LASTEXITCODE }; node 'scripts/build-electron.mjs'; exit $LASTEXITCODE }\"",
    "package:win": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/package-win.ps1",
    "smoke:electron": "powershell -NoProfile -ExecutionPolicy Bypass -Command \"& { node 'node_modules/electron/cli.js' 'scripts/smoke-electron.cjs'; exit $LASTEXITCODE }\"",
    "test": "powershell -NoProfile -ExecutionPolicy Bypass -Command \"& { node 'node_modules/vitest/vitest.mjs' run --pool=threads --maxWorkers=1; exit $LASTEXITCODE }\"",
    "test:watch": "powershell -NoProfile -ExecutionPolicy Bypass -Command \"& { node 'node_modules/vitest/vitest.mjs' --watch --pool=threads --maxWorkers=1; exit $LASTEXITCODE }\"",
    "typecheck": "powershell -NoProfile -ExecutionPolicy Bypass -Command \"& { node 'node_modules/typescript/bin/tsc' -p tsconfig.json --noEmit; if ($LASTEXITCODE -ne 0) { exit $LASTEXITCODE }; node 'node_modules/typescript/bin/tsc' -p tsconfig.electron.json --noEmit; exit $LASTEXITCODE }\""
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "dependencies": {
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@types/sql.js": "^1.4.11",
    "@vitejs/plugin-react": "^6.0.2",
    "concurrently": "^9.2.1",
    "esbuild": "^0.28.0",
    "lucide-react": "^1.16.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "sql.js": "^1.14.1",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3",
    "uuid": "^14.0.0",
    "vite": "^8.0.14",
    "vitest": "^4.1.7",
    "wait-on": "^9.0.10",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "electron": "^41.7.0",
    "electron-builder": "^26.0.12"
  },
  "build": {
    "appId": "local.storybound.replica",
    "electronDist": "node_modules/electron/dist",
    "productName": "Storybound Replica",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist-renderer/**/*",
      "dist-electron/**/*",
      "node_modules/sql.js/**/*",
      "package.json"
    ],
    "extraMetadata": {
      "main": "dist-electron/electron/main.js"
    },
    "asarUnpack": [
      "node_modules/sql.js/dist/*.wasm"
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "signAndEditExecutable": false,
      "artifactName": "Storybound-Replica-Setup-${version}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
